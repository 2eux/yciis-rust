{
  "name": "Secure School ERP",
  "description": "Enterprise secure school ERP system with Rust backend and SvelteKit frontend",
  "version": "1.0.0",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "./backend",
    "args": {
      "RUST_LOG": "info",
      "PORT": "3000"
    }
  },
  "ports": [
    {
      "host": 3000,
      "container": 3000,
      "protocol": "tcp"
    }
  ],
  "environment": [
    {
      "key": "DATABASE_URL",
      "value": "{{secret:database_url}}",
      "optional": false,
      "description": "PostgreSQL connection string (Supabase or self-hosted)"
    },
    {
      "key": "REDIS_URL",
      "value": "{{secret:redis_url}}",
      "optional": false,
      "description": "Redis connection string"
    },
    {
      "key": "JWT_SECRET",
      "value": "{{secret:jwt_secret}}",
      "optional": false,
      "description": "Secret for JWT signing (min 32 characters, use openssl rand -base64 32)"
    },
    {
      "key": "SUPABASE_URL",
      "value": "{{secret:supabase_url}}",
      "optional": false,
      "description": "Your Supabase project URL"
    },
    {
      "key": "SUPABASE_ANON_KEY",
      "value": "{{secret:supabase_anon_key}}",
      "optional": false,
      "description": "Supabase anonymous key"
    },
    {
      "key": "SUPABASE_SERVICE_KEY",
      "value": "{{secret:supabase_service_key}}",
      "optional": false,
      "description": "Supabase service role key"
    },
    {
      "key": "RUST_LOG",
      "value": "info",
      "optional": true
    },
    {
      "key": "PORT",
      "value": "3000",
      "optional": true
    },
    {
      "key": "MAX_LOGIN_ATTEMPTS",
      "value": "5",
      "optional": true
    },
    {
      "key": "LOCKOUT_DURATION_MINUTES",
      "value": "15",
      "optional": true
    },
    {
      "key": "AUDIT_LOG_RETENTION_DAYS",
      "value": "365",
      "optional": true
    }
  ],
  "secrets": [
    {
      "name": "database_url",
      "example": "postgresql://postgres:password@db.supabase.co:5432/postgres",
      "description": "PostgreSQL connection string"
    },
    {
      "name": "redis_url",
      "example": "redis://:password@redis.supabase.co:6379",
      "description": "Redis connection string"
    },
    {
      "name": "jwt_secret",
      "example": "openssl rand -base64 32",
      "description": "Strong secret key for JWT signing"
    },
    {
      "name": "supabase_url",
      "example": "https://your-project.supabase.co",
      "description": "Your Supabase project URL"
    },
    {
      "name": "supabase_anon_key",
      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
      "description": "Supabase anon key"
    },
    {
      "name": "supabase_service_key",
      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
      "description": "Supabase service role key"
    }
  ],
  "resources": {
    "postgres": {
      "enabled": true,
      "version": "15",
      "optional": false
    },
    "redis": {
      "enabled": true,
      "version": "7",
      "optional": false
    }
  },
  "health_check": {
    "enabled": true,
    "url": "/health",
    "interval": 30,
    "timeout": 10,
    "start_period": 30,
    "retries": 3
  },
  "deployment": {
    "type": "service",
    " replicas": 1,
    "autoscale": {
      "enabled": false,
      "min_replicas": 1,
      "max_replicas": 3,
      "cpu_threshold": 70
    }
  },
  "limits": {
    "cpu": "1.0",
    "memory": "512Mi"
  },
  "liveness_probe": {
    "path": "/health",
    "initial_delay_seconds": 30,
    "period_seconds": 30,
    "timeout_seconds": 10,
    "failure_threshold": 3
  },
  "readiness_probe": {
    "path": "/health",
    "initial_delay_seconds": 10,
    "period_seconds": 10,
    "timeout_seconds": 5,
    "failure_threshold": 3
  }
}